# ── VLM ──────────────────────────────────────────────────────────
VLM_BASE_URL=http://localhost:8000/v1
VLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_URL=postgresql://agent:change_me_strong_password@localhost:5432/macrodb

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@localhost:6379

# ── MinIO ─────────────────────────────────────────────────────────
MINIO_USER=minioadmin
MINIO_PASSWORD=change_me_minio_password
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=macro-recordings

# ── Qdrant ────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=workflows

# ── Langfuse ─────────────────────────────────────────────────────
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=your_public_key_here
LANGFUSE_SECRET_KEY=your_secret_key_here
LANGFUSE_SECRET=change_me_nextauth_secret
LANGFUSE_SALT=change_me_salt

# ── Vault ─────────────────────────────────────────────────────────
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=change_me_vault_token

# ── Grafana ───────────────────────────────────────────────────────
GRAFANA_PASSWORD=change_me_grafana_password

# ── App ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
MAX_RETRIES=3
HUMAN_APPROVAL_THRESHOLD=high
